---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Services from '../../components/Services.astro';
import About from '../../components/About.astro';
import Reviews from '../../components/Reviews.astro';
import Pricing from '../../components/Pricing.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Pepe Vejlupek – Handyman Prague",
  "description": "Handyman service for all of Prague. Furniture assembly, repairs, painting, plumbing and much more.",
  "url": "https://pepevejlupek.cz/en/",
  "telephone": "+420774399400",
  "email": "info@pepevejlupek.cz",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Prague",
    "addressCountry": "CZ"
  },
  "areaServed": [
    { "@type": "City", "name": "Prague" },
    { "@type": "AdministrativeArea", "name": "Prague 1" },
    { "@type": "AdministrativeArea", "name": "Prague 2" },
    { "@type": "AdministrativeArea", "name": "Prague 3" },
    { "@type": "AdministrativeArea", "name": "Prague 4" },
    { "@type": "AdministrativeArea", "name": "Prague 5" },
    { "@type": "AdministrativeArea", "name": "Prague 6" },
    { "@type": "AdministrativeArea", "name": "Prague 7" },
    { "@type": "AdministrativeArea", "name": "Prague 8" },
    { "@type": "AdministrativeArea", "name": "Prague 9" },
    { "@type": "AdministrativeArea", "name": "Prague 10" },
    { "@type": "AdministrativeArea", "name": "Prague 11" },
    { "@type": "AdministrativeArea", "name": "Prague 12" },
    { "@type": "Neighborhood", "name": "Vinohrady" },
    { "@type": "Neighborhood", "name": "Nusle" },
    { "@type": "Neighborhood", "name": "Žižkov" },
    { "@type": "Neighborhood", "name": "Smíchov" },
    { "@type": "Neighborhood", "name": "Košíře" },
    { "@type": "Neighborhood", "name": "Barrandov" },
    { "@type": "Neighborhood", "name": "Dejvice" },
    { "@type": "Neighborhood", "name": "Bubeneč" },
    { "@type": "Neighborhood", "name": "Vršovice" },
    { "@type": "Neighborhood", "name": "Strašnice" },
    { "@type": "Neighborhood", "name": "Modřany" },
    { "@type": "Neighborhood", "name": "Komořany" }
  ],
  "priceRange": "700–2100 CZK/hr",
  "openingHours": ["Mo-Fr 08:00-18:00"],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "500"
  }
};
---

<BaseLayout
  title="Pepe Vejlupek – I'll Just Fix It | Handyman Prague"
  description="Pepe Vejlupek – handyman in Prague. Whatever breaks, I fix it. Furniture assembly, repairs, painting, plumbing and more. Quick response, fair prices."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <main>
    <Hero />
    <TrustBar />
    <Services />
    <About />
    <Reviews />
    <Pricing />
    <Faq />
    <Contact />
  </main>
</BaseLayout>
