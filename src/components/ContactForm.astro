---
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<div class="contact-form">
  <h3>{t('form.heading')}</h3>
  <form id="contactForm" novalidate>
    <input type="text" name="name" id="name" style="display:none;" tabindex="-1" autocomplete="off" />

    <div class="form-row">
      <div class="form-group">
        <label for="fullname">{t('form.name')}</label>
        <input type="text" id="fullname" name="fullname" placeholder={t('form.namePlaceholder')} required />
      </div>
      <div class="form-group">
        <label for="email">{t('form.email')}</label>
        <input type="email" id="email" name="email" placeholder={t('form.emailPlaceholder')} required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="phone">{t('form.phone')}</label>
        <input type="tel" id="phone" name="phone" placeholder="+420 774 399 400" required />
      </div>
      <div class="form-group">
        <label for="location">{t('form.location')}</label>
        <select id="location" name="location" required>
          <option value="">{t('form.locationPlaceholder')}</option>
          <option value="Praha 1">Praha 1</option>
          <option value="Praha 2">Praha 2</option>
          <option value="Praha 3">Praha 3</option>
          <option value="Praha 4">Praha 4</option>
          <option value="Praha 5">Praha 5</option>
          <option value="Praha 6">Praha 6</option>
          <option value="Praha 7">Praha 7</option>
          <option value="Praha 8">Praha 8</option>
          <option value="Praha 9">Praha 9</option>
          <option value="Praha 10">Praha 10</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="service">{t('form.service')}</label>
        <select id="service" name="service" required>
          <option value="">{t('form.servicePlaceholder')}</option>
          <option>{t('form.s1')}</option>
          <option>{t('form.s2')}</option>
          <option>{t('form.s3')}</option>
          <option>{t('form.s4')}</option>
          <option>{t('form.s5')}</option>
          <option>{t('form.s6')}</option>
          <option>{t('form.s7')}</option>
          <option>{t('form.s8')}</option>
          <option>{t('form.s9')}</option>
          <option>{t('form.s10')}</option>
        </select>
      </div>
      <div class="form-group">
        <label for="date">{t('form.date')}</label>
        <input type="date" id="date" name="date" />
      </div>
    </div>

    <div class="form-group">
      <label for="message">{t('form.message')}</label>
      <textarea id="message" name="message" placeholder={t('form.messagePlaceholder')}></textarea>
    </div>

    <div class="form-group urgent-group">
      <label class="checkbox-label">
        <input type="checkbox" id="urgent" name="urgent" />
        <span class="checkbox-box"></span>
        <span class="checkbox-text">
          <strong>{t('form.onCall')}</strong>
          <span class="urgent-note">{t('form.onCallNote')}</span>
        </span>
      </label>
    </div>

    <p class="consent-text">
      {t('form.consent')} <a href={t('form.consentLinkHref')}>{t('form.consentLink')}</a> {t('form.consentEnd')}
    </p>

    <button
      type="submit"
      class="btn btn-primary form-submit"
      data-submit-label={t('form.submit')}
      data-sending-label={t('form.sending')}
      data-error-msg={t('form.errorMsg')}
    >{t('form.submit')}</button>
  </form>

  <div class="form-success" id="formSuccess">
    <span class="success-icon">✅</span>
    <h4>{t('form.successTitle')}</h4>
    <p>{t('form.successText')}</p>
  </div>
</div>

<script>
  // Set date input min to today
  const dateInput = document.getElementById('date') as HTMLInputElement | null;
  if (dateInput) {
    dateInput.min = new Date().toISOString().split('T')[0];
  }

  const form = document.getElementById('contactForm') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Honeypot
      const honeypot = document.getElementById('name') as HTMLInputElement;
      if (honeypot && honeypot.value) return;

      const btn = form.querySelector('.form-submit') as HTMLButtonElement;
      const submitLabel = btn.dataset.submitLabel ?? '📨 Odeslat poptávku';
      const sendingLabel = btn.dataset.sendingLabel ?? 'Odesílám…';
      const errorMsg = btn.dataset.errorMsg ?? 'Odeslání se nezdařilo. Zavolejte nám prosím na +420 774 399 400.';

      btn.disabled = true;
      btn.textContent = sendingLabel;

      const data = Object.fromEntries(new FormData(form).entries());

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.style.display = 'none';
          const success = document.getElementById('formSuccess');
          if (success) success.style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = submitLabel;
          alert(errorMsg);
        }
      } catch {
        btn.disabled = false;
        btn.textContent = submitLabel;
        alert(errorMsg);
      }
    });
  }
</script>

<style>
  .contact-form {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2rem;
  }
  .contact-form h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.5rem; }
  .form-group { margin-bottom: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  label { display: block; font-size: 0.88rem; font-weight: 600; margin-bottom: 0.35rem; }
  input, textarea, select {
    width: 100%;
    padding: var(--input-padding-y) var(--input-padding-x);
    border: var(--input-border);
    border-radius: var(--input-radius);
    font-size: var(--input-font-size);
    font-family: var(--font-body);
    background: var(--input-bg);
    color: var(--text);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    outline: none;
  }
  input:focus-visible, textarea:focus-visible, select:focus-visible {
    border: var(--input-border-focus);
    background: var(--input-bg-focus);
    outline: 2px solid var(--color-brand);
    outline-offset: 1px;
  }
  input:focus:not(:focus-visible), textarea:focus:not(:focus-visible), select:focus:not(:focus-visible) {
    border: var(--input-border-focus);
    background: var(--input-bg-focus);
  }
  textarea { resize: vertical; min-height: 100px; }
  .form-submit { width: 100%; margin-top: 0.25rem; font-size: 1.05rem; }

  /* On-call checkbox */
  .urgent-group { margin-bottom: 0.75rem; }
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
    margin-bottom: 0;
  }
  .checkbox-label input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .checkbox-box {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 1px;
    border: 1.5px solid var(--color-border-default);
    border-radius: var(--radius-xs);
    background: var(--input-bg);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .checkbox-label input[type="checkbox"]:checked + .checkbox-box {
    background: var(--primary);
    border-color: var(--primary);
  }
  .checkbox-label input[type="checkbox"]:checked + .checkbox-box::after {
    content: '';
    display: block;
    width: 5px;
    height: 9px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
  }
  .checkbox-label input[type="checkbox"]:focus-visible + .checkbox-box {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }
  .checkbox-text { font-size: 0.9rem; font-weight: 400; }
  .checkbox-text strong { display: block; font-weight: 700; font-size: 0.9rem; }
  .urgent-note {
    display: block;
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 0.1rem;
  }

  /* Consent */
  .consent-text {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .consent-text a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Success */
  .form-success {
    display: none;
    text-align: center;
    padding: 2rem;
  }
  .form-success .success-icon { font-size: 3rem; margin-bottom: 1rem; display: block; }
  .form-success h4 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; }
  .form-success p { color: var(--text-light); }

  @media (max-width: 768px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
