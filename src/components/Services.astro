---
import ServiceCard from './ServiceCard.astro';
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);

const services = [
  { icon: '🛋️', titleKey: 'service.furniture.title', descKey: 'service.furniture.desc' },
  { icon: '🎨', titleKey: 'service.painting.title',  descKey: 'service.painting.desc' },
  { icon: '🔨', titleKey: 'service.repairs.title',   descKey: 'service.repairs.desc' },
  { icon: '🚿', titleKey: 'service.plumbing.title',  descKey: 'service.plumbing.desc' },
  { icon: '🪛', titleKey: 'service.drilling.title',  descKey: 'service.drilling.desc' },
  { icon: '🔐', titleKey: 'service.locks.title',     descKey: 'service.locks.desc' },
  { icon: '💡', titleKey: 'service.lighting.title',  descKey: 'service.lighting.desc' },
  { icon: '🔌', titleKey: 'service.electrical.title',descKey: 'service.electrical.desc' },
  { icon: '🌿', titleKey: 'service.garden.title',    descKey: 'service.garden.desc' },
] as const;
---

<section id="sluzby">
  <div class="section-inner">
    <div class="section-header">
      <h2>{t('services.heading')}</h2>
      <p>{t('services.subheading')}</p>
    </div>
    <div class="services-grid">
      {services.map((s) => (
        <ServiceCard icon={s.icon} title={t(s.titleKey)} description={t(s.descKey)} />
      ))}
    </div>
  </div>
</section>

<style>
  #sluzby { background: var(--bg); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.2rem;
  }
</style>
