---
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const homeUrl = lang === 'en' ? '/en/' : '/';
const blogUrl = lang === 'en' ? '/en/blog' : '/blog';
---

<footer>
  <div class="footer-top">
    <div class="footer-inner">
      <div class="footer-logo">Pepe Vejlupek – <span>{t('nav.logoAccent')}</span></div>
      <p class="footer-tagline">{t('footer.tagline')}</p>
      <a href="tel:+420774399400" class="footer-phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        +420 774 399 400
      </a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-inner">
      <div class="footer-links">
        <a href={`${homeUrl}#sluzby`}>{t('footer.services')}</a>
        <a href={`${homeUrl}#cenik`}>{t('footer.pricing')}</a>
        <a href={`${homeUrl}#kontakt`}>{t('footer.contact')}</a>
        <a href={blogUrl}>{t('footer.blog')}</a>
        <a href={t('footer.termsHref')}>{t('footer.terms')}</a>
      </div>
      <p class="copyright">© {year} Josef Vejlupek. {t('footer.copyright')}</p>
    </div>
  </div>
</footer>

<style>
  .footer-top {
    background: var(--color-accent);
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  .footer-bottom {
    background: #111110;
    padding: 1.25rem 1.5rem;
    text-align: center;
  }
  .footer-inner { max-width: 700px; margin: 0 auto; }

  .footer-logo { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
  .footer-logo span { color: var(--nav-logo-accent); }
  .footer-tagline { font-size: 0.88rem; color: rgba(255,255,255,0.65); margin-bottom: 1.2rem; }
  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--primary);
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.6rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 1rem;
    transition: background var(--transition-base);
  }
  .footer-phone:hover { background: var(--primary-dark); }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .footer-links a { color: #888; text-decoration: none; font-size: 0.85rem; }
  .footer-links a:hover { color: var(--primary); }
  .copyright { font-size: 0.78rem; color: #888; } /* #888 on #111110 = 5.3:1 */
</style>
