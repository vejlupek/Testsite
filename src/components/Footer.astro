---
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const homeUrl = lang === 'en' ? '/en/' : '/';
const blogUrl = lang === 'en' ? '/en/blog' : '/blog';

const localLinks = lang === 'cs' ? {
  title: 'Hodinový manžel v Praze',
  links: [
    { href: '/blog/hodinovy-manzel-vinohrady', label: 'Vinohrady a Nusle (Praha 2)' },
    { href: '/blog/hodinovy-manzel-zizkov', label: 'Žižkov (Praha 3)' },
    { href: '/hodinovy-manzel-praha-5', label: 'Praha 5 – Smíchov, Košíře, Barrandov' },
    { href: '/blog/hodinovy-manzel-dejvice', label: 'Dejvice a Bubeneč (Praha 6)' },
    { href: '/blog/hodinovy-manzel-vrsovice', label: 'Vršovice a Strašnice (Praha 10)' },
    { href: '/blog/hodinovy-manzel-modrany', label: 'Modřany a Komořany (Praha 12)' },
  ],
} : {
  title: 'Handyman in Prague',
  links: [
    { href: '/en/blog/handyman-vinohrady-prague-2', label: 'Vinohrady & Nusle (Prague 2)' },
    { href: '/en/blog/handyman-zizkov-prague-3', label: 'Žižkov (Prague 3)' },
    { href: '/en/handyman-prague-5', label: 'Prague 5 – Smíchov, Košíře, Barrandov' },
    { href: '/en/blog/handyman-dejvice-prague-6', label: 'Dejvice & Bubeneč (Prague 6)' },
    { href: '/en/blog/handyman-vrsovice-prague-10', label: 'Vršovice & Strašnice (Prague 10)' },
    { href: '/en/blog/handyman-modrany-prague-12', label: 'Modřany & Komořany (Prague 12)' },
  ],
};
---

<footer>
  <div class="footer-top">
    <div class="footer-inner">
      <div class="footer-logo">Pepe Vejlupek – <span>{t('nav.logoAccent')}</span></div>
      <p class="footer-tagline">{t('footer.tagline')}</p>
      <a href="tel:+420774399400" class="footer-phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        +420 774 399 400
      </a>
    </div>
  </div>
  <div class="footer-local">
    <div class="footer-inner footer-inner--wide">
      <p class="footer-local-title">{localLinks.title}</p>
      <ul class="footer-local-links">
        {localLinks.links.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-inner">
      <div class="footer-links">
        <a href={`${homeUrl}#sluzby`}>{t('footer.services')}</a>
        <a href={`${homeUrl}#cenik`}>{t('footer.pricing')}</a>
        <a href={`${homeUrl}#kontakt`}>{t('footer.contact')}</a>
        <a href={blogUrl}>{t('footer.blog')}</a>
        <a href={t('footer.termsHref')}>{t('footer.terms')}</a>
      </div>
      <p class="copyright">© {year} Josef Vejlupek. {t('footer.copyright')}</p>
    </div>
  </div>
</footer>

<style>
  .footer-top {
    background: var(--color-accent);
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  .footer-bottom {
    background: #111110;
    padding: 1.25rem 1.5rem;
    text-align: center;
  }
  .footer-inner { max-width: 700px; margin: 0 auto; }

  .footer-logo { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
  .footer-logo span { color: var(--nav-logo-accent); }
  .footer-tagline { font-size: 0.88rem; color: rgba(255,255,255,0.65); margin-bottom: 1.2rem; }
  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--primary);
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.6rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 1rem;
    transition: background var(--transition-base);
  }
  .footer-phone:hover { background: var(--primary-dark); }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .footer-links a { color: #888; text-decoration: none; font-size: 0.85rem; }
  .footer-links a:hover { color: var(--primary); }
  .copyright { font-size: 0.78rem; color: #888; } /* #888 on #111110 = 5.3:1 */

  /* Local SEO section */
  .footer-local {
    background: color-mix(in srgb, var(--color-accent) 85%, #000);
    padding: 1.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .footer-inner--wide { max-width: 960px; }
  .footer-local-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.75);
    margin-bottom: 0.6rem;
  }
  .footer-local-links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.5rem;
    padding: 0;
    margin: 0;
  }
  .footer-local-links a {
    color: rgba(255,255,255,0.82);
    text-decoration: none;
    font-size: 0.82rem;
    transition: color var(--transition-base);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .footer-local-links a:hover { color: var(--primary); }
</style>
