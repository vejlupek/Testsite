---
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<div class="trust-bar">
  <div class="trust-bar-inner">
    <div class="trust-item"><span class="icon">⭐</span> {t('trust.rating')}</div>
    <div class="trust-item"><span class="icon">🏠</span> {t('trust.jobs')}</div>
    <div class="trust-item"><span class="icon">⚡</span> {t('trust.response')}</div>
    <div class="trust-item"><span class="icon">📍</span> {t('trust.coverage')}</div>
    <div class="trust-item"><span class="icon">💳</span> {t('trust.payment')}</div>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--color-navy-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.9rem 1.5rem;
  }
  .trust-bar-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.80);
    font-weight: 500;
  }
  .trust-item .icon { font-size: 1.1rem; }

  @media (max-width: 768px) {
    .trust-bar-inner { gap: 1.1rem; }
    .trust-item { font-size: 0.82rem; }
  }
</style>
