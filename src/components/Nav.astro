---
import { getLang, useTranslations, getAlternateLangUrl } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);

const homeUrl = lang === 'en' ? '/en/' : '/';
const blogUrl = lang === 'en' ? '/en/blog' : '/blog';
const isHome = Astro.url.pathname === homeUrl || Astro.url.pathname === homeUrl.replace(/\/$/, '');
const alternateLangUrl = getAlternateLangUrl(Astro.url.pathname);
const alternateLangLabel = lang === 'en' ? 'CS' : 'EN';

function sectionLink(anchor: string): string {
  return isHome ? `#${anchor}` : `${homeUrl}#${anchor}`;
}
---

<nav>
  <div class="nav-inner">
    <a href={isHome ? '#' : homeUrl} class="nav-logo">Pepe Vejlupek<br><span>{t('nav.logoAccent')}</span></a>
    <ul class="nav-links">
      <li><a href={sectionLink('sluzby')}>{t('nav.services')}</a></li>
      <li><a href={sectionLink('o-mne')}>{t('nav.about')}</a></li>
      <li><a href={sectionLink('reference')}>{t('nav.references')}</a></li>
      <li><a href={sectionLink('cenik')}>{t('nav.pricing')}</a></li>
      <li><a href={blogUrl}>{t('nav.blog')}</a></li>
      <li><a href={sectionLink('kontakt')} class="nav-cta">{t('nav.contact')}</a></li>
      <li><a href={alternateLangUrl} class="nav-lang">{alternateLangLabel}</a></li>
    </ul>
    <div class="nav-mobile-right">
      <a href={alternateLangUrl} class="nav-lang-mobile">{alternateLangLabel}</a>
      <a href="tel:+420774399400" class="nav-phone-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        {t('nav.call')}
      </a>
      <button class="hamburger" aria-label="Otevřít menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul>
      <li><a href={sectionLink('sluzby')}>{t('nav.services')}</a></li>
      <li><a href={sectionLink('o-mne')}>{t('nav.about')}</a></li>
      <li><a href={sectionLink('reference')}>{t('nav.references')}</a></li>
      <li><a href={sectionLink('cenik')}>{t('nav.pricing')}</a></li>
      <li><a href={blogUrl}>{t('nav.blog')}</a></li>
      <li><a href={sectionLink('kontakt')} class="mobile-cta">{t('nav.contact')}</a></li>
    </ul>
  </div>
</nav>

<script>
  const hamburger = document.querySelector('.hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    hamburger.classList.toggle('is-open', !isOpen);
    mobileMenu?.classList.toggle('is-open', !isOpen);
    if (mobileMenu) mobileMenu.setAttribute('aria-hidden', String(isOpen));
  });

  // Close menu when a link is clicked
  mobileMenu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.classList.remove('is-open');
      mobileMenu.classList.remove('is-open');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>

{isHome && (
  <script>
    const sections = Array.from(document.querySelectorAll('section[id]')) as HTMLElement[];
    const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
    let offsets: { id: string; top: number }[] = [];
    function cacheOffsets() {
      offsets = sections.map((s) => ({ id: s.id, top: s.offsetTop }));
    }
    cacheOffsets();
    window.addEventListener('resize', cacheOffsets, { passive: true });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          let current = '';
          for (const o of offsets) {
            if (y >= o.top - 100) current = o.id;
          }
          navLinks.forEach((a) => {
            (a as HTMLElement).style.color =
              a.getAttribute('href') === '#' + current ? '#ffffff' : '';
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  </script>
)}

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-border);
    padding: 0 1.5rem;
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .nav-logo {
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.25;
    color: var(--nav-logo-color);
    text-decoration: none;
  }
  .nav-logo span { color: var(--nav-logo-accent); }
  .nav-links { display: flex; gap: 1.8rem; list-style: none; align-items: center; }
  .nav-links a {
    text-decoration: none;
    color: var(--nav-link-color);
    font-size: 0.95rem;
    transition: color var(--transition-fast);
  }
  .nav-links a:hover { color: var(--nav-link-hover); }
  .nav-cta {
    background: var(--primary);
    color: #fff !important;
    padding: var(--btn-padding-y-sm) var(--btn-padding-x-sm);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
    transition: background var(--transition-base) !important;
  }
  .nav-cta:hover { background: var(--primary-dark) !important; color: #fff !important; }

  /* Language switcher */
  .nav-lang {
    font-size: 0.82rem !important;
    font-weight: 700 !important;
    color: rgba(255,255,255,0.55) !important;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-sm);
    letter-spacing: 0.04em;
    transition: color var(--transition-fast), border-color var(--transition-fast) !important;
  }
  .nav-lang:hover { color: #fff !important; border-color: rgba(255,255,255,0.5) !important; }

  /* Mobile right group */
  .nav-mobile-right { display: none; align-items: center; gap: 0.5rem; }

  .nav-lang-mobile {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  /* Mobile call button */
  .nav-phone-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--primary);
    color: #fff;
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
    font-size: 0.92rem;
    text-decoration: none;
    transition: background var(--transition-base);
  }
  .nav-phone-btn:hover { background: var(--primary-dark); }

  /* Hamburger button */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
  }
  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown menu */
  .mobile-menu {
    display: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: var(--nav-bg);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .mobile-menu.is-open {
    max-height: 400px;
  }
  .mobile-menu ul {
    list-style: none;
    padding: 0.5rem 0 1rem;
    margin: 0;
  }
  .mobile-menu li a {
    display: block;
    padding: 0.75rem 1.5rem;
    color: var(--nav-link-color);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-menu li a:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .mobile-menu .mobile-cta {
    margin: 0.5rem 1.5rem 0;
    display: block;
    background: var(--primary);
    color: #fff !important;
    text-align: center;
    padding: 0.65rem 1rem;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
    transition: background var(--transition-base);
  }
  .mobile-menu .mobile-cta:hover { background: var(--primary-dark) !important; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-mobile-right { display: flex; }
    .mobile-menu { display: block; }
  }
</style>
