---
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<section id="cenik">
  <div class="section-inner">
    <div class="section-header">
      <h2>{t('pricing.heading')}</h2>
      <p>{t('pricing.subheading')}</p>
    </div>
    <div class="pricing-cards">

      <div class="pricing-card featured">
        <div class="card-label">{t('pricing.min.label')}</div>
        <div class="card-price">{t('pricing.min.price')}</div>
        <div class="card-note">{t('pricing.min.note')}</div>
      </div>

      <div class="pricing-card featured">
        <div class="card-label">{t('pricing.hour.label')}</div>
        <div class="card-price">{t('pricing.hour.price')}</div>
        <div class="card-note">{t('pricing.hour.note')}</div>
      </div>

      <div class="pricing-card muted">
        <div class="card-label">{t('pricing.material.label')}</div>
        <div class="card-price large">{t('pricing.material.value')}</div>
      </div>

    </div>
    <p class="pricing-footer">{t('pricing.footer')}</p>
  </div>
</section>

<style>
  #cenik { background: #fff; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-card {
    border-radius: var(--radius-xl);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }

  .pricing-card.featured {
    border: 2px solid var(--primary);
    background: #fff;
  }

  .pricing-card.muted {
    background: #f0f0f0;
    border: 2px solid transparent;
  }

  .card-label {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.4;
    min-height: 2.8em;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-price {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: var(--font-weight-bold);
    color: var(--text);
    line-height: 1.1;
  }

  .card-price.large {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .card-note {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .pricing-footer {
    max-width: 900px;
    margin: 1.5rem auto 0;
    font-size: var(--text-sm);
    color: var(--text-light);
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .pricing-cards { grid-template-columns: 1fr; }
    .card-label { min-height: unset; }
  }
</style>
