---
import ContactForm from './ContactForm.astro';
---

<section id="kontakt">
  <div class="section-inner">
    <div class="section-header">
      <h2>Ozvěte se mi!</h2>
      <p>Odpovím vám do 2 hodin – většinou mnohem dříve</p>
    </div>

    <!-- Prominentní volací banner -->
    <div class="call-banner">
      <div class="call-banner-text">
        <strong>Neváhejte zavolat</strong>
        <span>Zvedám telefon osobně · odpovídám rychle</span>
      </div>
      <a href="tel:+420774399400" class="call-banner-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        <span>+420 774 399 400</span>
      </a>
    </div>

    <div class="contact-grid">
      <div class="contact-info">
        <h3>Kontaktní údaje</h3>
        <div class="contact-items">
          <div class="contact-item">
            <span class="contact-item-icon">📞</span>
            <div class="contact-item-text">
              <strong>Telefon</strong>
              <a href="tel:+420774399400">+420 774 399 400</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-item-icon">✉️</span>
            <div class="contact-item-text">
              <strong>E-mail</strong>
              <a href="mailto:info@pepevejlupek.cz">info@pepevejlupek.cz</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-item-icon">🕐</span>
            <div class="contact-item-text">
              <strong>Pracovní doba</strong>
              <p>Po–Pá: 8:00 – 18:00<br />Ostatní časy: pohotovost</p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-item-icon">📍</span>
            <div class="contact-item-text">
              <strong>Oblast působení</strong>
              <p>Praha a blízké okolí</p>
            </div>
          </div>
        </div>
      </div>
      <ContactForm />
    </div>
  </div>
</section>

<style>
  #kontakt { background: var(--bg); }

  /* Call banner */
  .call-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: var(--color-accent);
    border-radius: var(--radius-xl);
    padding: 1.5rem 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .call-banner-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .call-banner-text strong {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
  }
  .call-banner-text span {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.72);
  }
  .call-banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary);
    color: #fff;
    text-decoration: none;
    padding: 0.9rem 2rem;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-bold);
    font-size: 1.2rem;
    box-shadow: 0 4px 16px rgba(176, 90, 13, 0.4);
    transition: all var(--transition-base);
    white-space: nowrap;
  }
  .call-banner-btn:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(176, 90, 13, 0.55);
  }
  .call-banner-btn span { font-size: 1.25rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }
  .contact-info h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }
  .contact-items { display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }
  .contact-item-icon { font-size: 1.5rem; flex-shrink: 0; }
  .contact-item-text strong {
    display: block;
    font-size: 0.82rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.2rem;
  }
  .contact-item-text a {
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
  }
  .contact-item-text a:hover { color: var(--primary); }
  .contact-item-text p { font-size: 0.95rem; font-weight: 600; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .call-banner { flex-direction: column; align-items: flex-start; }
    .call-banner-btn { width: 100%; justify-content: center; }
  }
</style>
